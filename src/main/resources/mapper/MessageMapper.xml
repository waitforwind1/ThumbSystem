<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.usst.thumbs.mapper.MessageMapper">

    <resultMap id="BaseResultMap" type="com.usst.thumbs.model.Message">
        <id property="id" column="id" />
        <result property="senderId" column="sender_id" />
        <result property="receiverId" column="receiver_id" />
        <result property="blogId" column="blog_id" />
        <result property="commentId" column="comment_id" />
        <result property="type" column="type" />
        <result property="createTime" column="create_time" />
        <result property="isRead" column="is_read" />
        <result property="isDelete" column="is_delete" />
        <result property="content" column="content" />
        <result property="title" column="title" />
    </resultMap>

    <sql id="Base_Column_List">
        id,sender_id,receiver_id,blog_id,comment_id,type,
        create_time,is_read,is_delete,content,title
    </sql>
</mapper>
