<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.usst.thumbs.mapper.BlogMapper">

    <resultMap id="BaseResultMap" type="com.usst.thumbs.model.Blog">
        <id property="id" column="id" />
        <result property="userId" column="user_id" />
        <result property="title" column="title" />
        <result property="content" column="content" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
        <result property="thumbCount" column="thumb_count" />
        <result property="coverImage" column="cover_image" />
        <result property="commentCount" column="comment_count" />
        <result property="favoriteCount" column="favorite_count" />
        <result property="shareCount" column="share_count" />
        <result property="hotScore" column="hot_score" />
        <result property="viewCount" column="view_count" />
        <result property="status" column="status" />
        <result property="isDelete" column="is_delete" />
    </resultMap>

    <update id="batchUpdateThumbCount">
        UPDATE blog
        SET thumb_count = thumb_count + CASE id
        <foreach collection="countMap" item="value" index="key">
            WHEN #{key} THEN #{value}
        </foreach>
        END
        WHERE id IN
        <foreach collection="countMap.keySet()" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

    <update id="batchUpdateFavoriteCount">
        update blog
        SET favorite_count = favorite_count + CASE id
        <foreach collection="countMap" item="value" index="key">
            WHEN #{key} THEN #{value}
        </foreach>
        END
        WHERE id IN
        <foreach collection="countMap.keySet()" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

    <update id="batchUpdateCommentCount">
        UPDATE blog
        SET comment_count = comment_count + CASE id
        <foreach collection="countMap" item="value" index="key">
            WHEN #{key} THEN #{value}
        </foreach>
        END
        WHERE id IN
        <foreach collection="countMap.keySet()" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>

    </update>


    <sql id="Base_Column_List">
        id,user_id,title,content,create_time,update_time,
        thumb_count,cover_image,comment_count,favorite_count,share_count,
        hot_score,view_count,status,is_delete
    </sql>
</mapper>
